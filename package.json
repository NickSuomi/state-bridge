    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  }
